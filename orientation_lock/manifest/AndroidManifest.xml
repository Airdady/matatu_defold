<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <application>
        <!-- Defold's own generated activity class, shared by every Defold
             Android project regardless of package name. Hard-locks to a
             single landscape direction (not "sensorLandscape", which still
             lets the OS flip between landscape and reverse-landscape as the
             device physically rotates 180°) so the game never changes
             direction no matter how the player holds the device. -->
        <activity android:name="com.dynamo.android.DefoldActivity"
            android:screenOrientation="landscape"
            tools:replace="android:screenOrientation" />
    </application>
</manifest>
