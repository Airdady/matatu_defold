local emoji_popover = require("modules.emoji_popover")
local akira = require("modules.akira")

-- Target mapped precisely to the /controller object to guarantee routing.
local GAME = "/controller#game_logic"

-- Layout constants
local LOGICAL_W = 1280
local LOGICAL_H = 720
local EXIT_BTN_SIZE = 80 
local EXIT_BTN_MARGIN_TOP = 10 
local EXIT_BTN_MARGIN_RIGHT = 10 
local EXIT_POPOVER_WIDTH = 200
local EXIT_POPOVER_HEIGHT = 120
local EXIT_POPOVER_OFFSET_Y = -10
local AVATAR_CONTAINER_SIZE = 80
local AVATAR_BG_COLOR  = vmath.vector4(0, 0, 0, 0) -- Transparent
local TIMER_RADIUS = 46
local STAKE_CHIP_SIZE = 170

-- UI Colors
local C_PANEL          = vmath.vector4(0.10, 0.10, 0.10, 0.95)
local C_PANEL_BORDER   = vmath.vector4(0.30, 0.30, 0.30, 1.0)
local C_TEXT           = vmath.vector4(0.95, 0.97, 0.95, 1.0)
local C_WHITE          = vmath.vector4(1.0, 1.0, 1.0, 1.0)
local C_SKIP_TEXT      = vmath.vector4(0.90, 0.91, 0.92, 1.0)
local BTN_BG_COLOR     = vmath.vector4(0, 0, 0, 0.25)

-- Defining specific colors for the Flip Clock...
local C_CARD_TOP = vmath.vector4(0.18, 0.18, 0.18, 1.0)
local C_CARD_BOT = vmath.vector4(0.12, 0.12, 0.12, 1.0)
local C_ACCENT   = vmath.vector4(0.906, 0.298, 0.235, 1.0) -- Match Point Red
local C_ORANGE   = vmath.vector4(0.953, 0.612, 0.071, 1.0) -- Needs Wins Orange

-- Timer colors
local C_T_GREEN  = vmath.vector4(0.13, 0.77, 0.37, 0.6)
local C_T_ORANGE = vmath.vector4(0.96, 0.62, 0.04, 0.6)
local C_T_RED    = vmath.vector4(0.94, 0.27, 0.27, 0.6)

-- Head-to-head form badges (W green / L red) + rating tiers
local C_FORM_W   = vmath.vector4(0.15, 0.70, 0.25, 1.0)
local C_FORM_L   = vmath.vector4(0.90, 0.25, 0.25, 1.0)
local C_H2H_GOLD = vmath.vector4(1.00, 0.84, 0.20, 1.0)
local C_H2H_DIM  = vmath.vector4(0.55, 0.58, 0.62, 1.0)

-- Round dots (wins needed to take the match, checked off per round won)
local C_DOT_RIM   = vmath.vector4(0.02, 0.02, 0.02, 0.95)
local C_DOT_EMPTY = vmath.vector4(0.38, 0.40, 0.43, 0.85)
local C_DOT_FILL  = vmath.vector4(1.00, 0.84, 0.20, 1.0)
local C_DOT_FLASH = vmath.vector4(1.00, 1.00, 1.00, 1.0)
local C_STORY_CYAN = vmath.vector4(0.0, 0.722, 0.831, 1.0)

local function box(pos, size, color, pivot)
    local n = gui.new_box_node(pos, size)
    gui.set_color(n, color)
    if pivot then gui.set_pivot(n, pivot) end
    return n
end

local function label(pos, text, size, color, align, font_name)
    local n = gui.new_text_node(pos, text)
    gui.set_font(n, font_name or "body")

    -- To fix text blurring, we assume large fonts like poppins_bold have a higher native size.
    local base_size = 24
    if font_name == "poppins_bold" or font_name == "title" or font_name == "helvetica_bold" then
        base_size = 36
    end

    gui.set_scale(n, vmath.vector3(size / base_size, size / base_size, 1.0))
    gui.set_color(n, color or C_TEXT)
    gui.set_pivot(n, align or gui.PIVOT_CENTER)
    return n
end

-- FLIP CLOCK LOGIC

-- Constructing the highly realistic 3D flip clock nodes...
local function create_flipper(parent, pos)
    -- Slightly shrunk from 150x110 to 130x100 for a tighter scoreboard
    local root = box(pos, vmath.vector3(130, 100, 0), vmath.vector4(0.06, 0.06, 0.06, 1.0), gui.PIVOT_CENTER)
    gui.set_parent(root, parent)

    -- Hinges appropriately shifted
    local gear_l = box(vmath.vector3(-65, 0, 0), vmath.vector3(8, 20, 0), vmath.vector4(0.04, 0.04, 0.04, 1.0), gui.PIVOT_CENTER)
    local gear_r = box(vmath.vector3(65, 0, 0), vmath.vector3(8, 20, 0), vmath.vector4(0.04, 0.04, 0.04, 1.0), gui.PIVOT_CENTER)
    gui.set_parent(gear_l, root)
    gui.set_parent(gear_r, root)

    -- Stencil mask to slice the cards perfectly in half
    local function make_half(pivot, color)
        local half = box(vmath.vector3(0, 0, 0), vmath.vector3(130, 50, 0), color, pivot)
        gui.set_clipping_mode(half, gui.CLIPPING_MODE_STENCIL)
        gui.set_parent(half, root)

        -- Adjusted font size (80) to perfectly fit inside the 130x100 clock
        local lbl = label(vmath.vector3(0, 0, 0), "00", 80, C_WHITE, gui.PIVOT_CENTER, "helvetica_bold")
        -- Add text shadow for realistic engraved look
        gui.set_shadow(lbl, vmath.vector4(0, 0, 0, 0.6))
        gui.set_parent(lbl, half)

        -- Lighting Shadow Overlay box
        local shadow = box(vmath.vector3(0, 0, 0), vmath.vector3(130, 50, 0), vmath.vector4(0,0,0,0), pivot)
        gui.set_parent(shadow, half)

        return half, lbl, shadow
    end

    -- Create layers (Back static layer, Front animating layer)
    local stat_top, stat_top_lbl, _ = make_half(gui.PIVOT_S, C_CARD_TOP)
    local stat_bot, stat_bot_lbl, stat_bot_shd = make_half(gui.PIVOT_N, C_CARD_BOT)
    local flip_top, flip_top_lbl, flip_top_shd = make_half(gui.PIVOT_S, C_CARD_TOP)
    local flip_bot, flip_bot_lbl, flip_bot_shd = make_half(gui.PIVOT_N, C_CARD_BOT)

    gui.set_enabled(flip_top, false)
    gui.set_enabled(flip_bot, false)

    -- Card middle crease separator
    local div = box(vmath.vector3(0, 0, 0), vmath.vector3(130, 2, 0), vmath.vector4(0,0,0,0.8), gui.PIVOT_CENTER)
    gui.set_parent(div, root)

    return {
        root = root,
        val = "00",
        stat_top = stat_top_lbl,
        stat_bot = stat_bot_lbl,
        stat_bot_shd = stat_bot_shd,
        flip_top_bg = flip_top,
        flip_top_lbl = flip_top_lbl,
        flip_top_shd = flip_top_shd,
        flip_bot_bg = flip_bot,
        flip_bot_lbl = flip_bot_lbl,
        flip_bot_shd = flip_bot_shd,
        is_flipping = false
    }
end

-- Animating the flip with realistic 3D lighting shadows...
local function animate_flipper(flipper, new_val)
    if flipper.val == new_val then return end

    -- Fast forward if it is already mid-animation to prevent weird visual overlaps
    if flipper.is_flipping then
        gui.cancel_animation(flipper.flip_top_bg, "euler.x")
        gui.cancel_animation(flipper.flip_bot_bg, "euler.x")
        gui.cancel_animation(flipper.flip_top_shd, "color.w")
        gui.cancel_animation(flipper.flip_bot_shd, "color.w")
        gui.cancel_animation(flipper.stat_bot_shd, "color.w")

        gui.set_enabled(flipper.flip_top_bg, false)
        gui.set_enabled(flipper.flip_bot_bg, false)
        gui.set_text(flipper.stat_top, flipper.val)
        gui.set_text(flipper.stat_bot, flipper.val)
        flipper.is_flipping = false
    end

    flipper.is_flipping = true
    local old_val = flipper.val
    flipper.val = new_val

    -- 1. Setup Starting States
    gui.set_text(flipper.stat_top, new_val)
    gui.set_text(flipper.stat_bot, old_val)

    -- The old top card that will fall down
    gui.set_text(flipper.flip_top_lbl, old_val)
    gui.set_rotation(flipper.flip_top_bg, vmath.vector3(0,0,0))
    local c_t_shd = gui.get_color(flipper.flip_top_shd); c_t_shd.w = 0; gui.set_color(flipper.flip_top_shd, c_t_shd)
    gui.set_enabled(flipper.flip_top_bg, true)

    -- The new bottom card that will swing into place
    gui.set_text(flipper.flip_bot_lbl, new_val)
    gui.set_rotation(flipper.flip_bot_bg, vmath.vector3(90,0,0))
    local c_b_shd = gui.get_color(flipper.flip_bot_shd); c_b_shd.w = 0.8; gui.set_color(flipper.flip_bot_shd, c_b_shd)
    gui.set_enabled(flipper.flip_bot_bg, true)

    -- Static back shadow that darkens while the top falls
    local c_s_shd = gui.get_color(flipper.stat_bot_shd); c_s_shd.w = 0; gui.set_color(flipper.stat_bot_shd, c_s_shd)

    -- 2. Execute Animation Step 1: Top card falls fast (gravity)
    gui.animate(flipper.flip_top_bg, "euler.x", -90, gui.EASING_INQUAD, 0.15, 0, function()
        gui.set_enabled(flipper.flip_top_bg, false)
        gui.set_text(flipper.stat_bot, new_val)

        -- Step 2: Bottom card swings out and bounces mechanically like real paper
        gui.animate(flipper.flip_bot_bg, "euler.x", 0, gui.EASING_OUTBOUNCE, 0.40, 0, function()
            gui.set_enabled(flipper.flip_bot_bg, false)
            flipper.is_flipping = false
        end)
        -- Shadow fades out as it lands
        gui.animate(flipper.flip_bot_shd, "color.w", 0.0, gui.EASING_OUTBOUNCE, 0.40)
        gui.animate(flipper.stat_bot_shd, "color.w", 0.0, gui.EASING_OUTBOUNCE, 0.40)
    end)

    -- Top card gets darker as it falls towards the bottom
    gui.animate(flipper.flip_top_shd, "color.w", 0.8, gui.EASING_INQUAD, 0.15)
    -- Static bottom gets darker as top falls over it
    gui.animate(flipper.stat_bot_shd, "color.w", 0.6, gui.EASING_INQUAD, 0.15)
end

-- ── Round dots & Skirting Footer ─────────────────────────────────────────────
-- Dynamically wraps to a second row to fit within the flip clock width.
local function build_round_dots(flipper, is_top)
    flipper.dots = {}
    flipper.dots_filled = 0
    flipper.is_top = is_top

    -- Add a visual skirting base attached directly to the scoreboard 
    flipper.skirting = box(vmath.vector3(0, 0, 0), vmath.vector3(130, 40, 0), vmath.vector4(0.08, 0.08, 0.08, 1), gui.PIVOT_CENTER)
    gui.set_parent(flipper.skirting, flipper.root)
    gui.set_enabled(flipper.skirting, false)

    for i = 1, 5 do
        local rim = gui.new_pie_node(vmath.vector3(0, 0, 0), vmath.vector3(20, 20, 0))
        gui.set_color(rim, C_DOT_RIM)
        gui.set_parent(rim, flipper.root)
        local fill = gui.new_pie_node(vmath.vector3(1.0, -1.0, 0), vmath.vector3(14, 14, 0))
        gui.set_color(fill, C_DOT_EMPTY)
        gui.set_parent(fill, rim)
        gui.set_enabled(rim, false)
        flipper.dots[i] = { rim = rim, fill = fill }
    end
end

local function hide_round_dots(flipper)
    if not (flipper and flipper.dots) then return end
    for i = 1, 5 do gui.set_enabled(flipper.dots[i].rim, false) end
    if flipper.skirting then gui.set_enabled(flipper.skirting, false) end
    flipper.dots_filled = 0
end

local function set_round_dots(flipper, needed, won, animate)
    if not (flipper and flipper.dots) then return end
    needed = math.max(1, math.min(5, tonumber(needed) or 1))
    won = math.max(0, math.min(tonumber(won) or 0, needed))

    local spacing_x = 30
    local spacing_y = 26
    local dir_y = flipper.is_top and 1 or -1
    local card_edge_y = flipper.is_top and 50 or -50

    -- Size and position the skirting container to encompass all rows
    local rows = math.ceil(needed / 3)
    local skirting_h = rows * spacing_y + 12
    if flipper.skirting then
        gui.set_size(flipper.skirting, vmath.vector3(130, skirting_h, 0))
        local sy = card_edge_y + dir_y * (skirting_h / 2)
        gui.set_position(flipper.skirting, vmath.vector3(0, sy, 0))
        gui.set_enabled(flipper.skirting, true)
    end

    local base_y = card_edge_y + dir_y * 18
    for i = 1, 5 do
        local d = flipper.dots[i]
        gui.set_enabled(d.rim, i <= needed)
        if i <= needed then
            -- Grid wrapping logic: Max 3 items per row
            local row = math.floor((i - 1) / 3)
            local col_index = (i - 1) % 3
            local items_in_row = math.min(3, needed - row * 3)
            
            local x0 = -((items_in_row - 1) * spacing_x) / 2
            local x = x0 + col_index * spacing_x
            local y = base_y + dir_y * (row * spacing_y)
            
            gui.set_position(d.rim, vmath.vector3(x, y, 0))
            
            gui.cancel_animation(d.fill, "scale")
            gui.set_scale(d.fill, vmath.vector3(1, 1, 1))
            gui.set_color(d.fill, (i <= won) and C_DOT_FILL or C_DOT_EMPTY)
        end
    end

    local prev = flipper.dots_filled or 0
    if animate and won > prev and flipper.dots[won] then
        local d = flipper.dots[won]
        gui.set_color(d.fill, C_DOT_FLASH)
        gui.set_scale(d.fill, vmath.vector3(0.1, 0.1, 1))
        gui.animate(d.fill, "scale", vmath.vector3(1.6, 1.6, 1), gui.EASING_OUTBACK, 0.38, 0.05, function()
            gui.animate(d.fill, "scale", vmath.vector3(1, 1, 1), gui.EASING_OUTSINE, 0.20)
            gui.set_color(d.fill, C_DOT_FILL)
        end)
    end
    flipper.dots_filled = won
end

-- Snap a flipper to a value with no animation (used by resets).
local function snap_flipper(flipper, new_val)
    if not flipper then return end
    gui.cancel_animation(flipper.flip_top_bg, "euler.x")
    gui.cancel_animation(flipper.flip_bot_bg, "euler.x")
    gui.set_enabled(flipper.flip_top_bg, false)
    gui.set_enabled(flipper.flip_bot_bg, false)
    flipper.is_flipping = false
    flipper.val = new_val
    gui.set_text(flipper.stat_top, new_val)
    gui.set_text(flipper.stat_bot, new_val)
end

-- BUILDERS

local function build_network_badge(parent, pos)
    local bg = box(pos, vmath.vector3(80, 24, 0), vmath.vector4(0.1, 0.1, 0.1, 0.6), gui.PIVOT_CENTER)
    gui.set_parent(bg, parent)
    local dot = box(vmath.vector3(-20, 0, 0), vmath.vector3(12, 12, 0), C_T_GREEN, gui.PIVOT_CENTER)
    gui.set_parent(dot, bg)
    local lbl = label(vmath.vector3(-5, 0, 0), "Good", 12, C_T_GREEN, gui.PIVOT_W, "poppins_bold")
    gui.set_parent(lbl, bg)
    return { bg = bg, dot = dot, lbl = lbl }
end

local function build_avatars_and_sections(self)
    -- Push left slightly to give extra margin space (shifted to right)
    local left_edge_x = 120
    self.hud_root = box(vmath.vector3(left_edge_x, LOGICAL_H/2, 0), vmath.vector3(160, 680, 0), vmath.vector4(0, 0, 0, 0), gui.PIVOT_CENTER)
    gui.set_xanchor(self.hud_root, gui.ANCHOR_LEFT)
    gui.set_yanchor(self.hud_root, gui.ANCHOR_NONE)

    -- PLAYER 2 OPPONENT SECTION (Shifted slightly top)
    self.o_avatar_bg = box(vmath.vector3(0, 300, 0), vmath.vector3(AVATAR_CONTAINER_SIZE, AVATAR_CONTAINER_SIZE, 0), AVATAR_BG_COLOR, gui.PIVOT_CENTER)
    gui.set_parent(self.o_avatar_bg, self.hud_root)

    self.o_timer = gui.new_pie_node(vmath.vector3(0, 0, 0), vmath.vector3(TIMER_RADIUS*2, TIMER_RADIUS*2, 0))
    gui.set_rotation(self.o_timer, vmath.vector3(0, 0, 90))
    gui.set_parent(self.o_timer, self.o_avatar_bg)
    gui.set_enabled(self.o_timer, false)

    self.o_avatar_img = box(vmath.vector3(0, 0, 0), vmath.vector3(AVATAR_CONTAINER_SIZE, AVATAR_CONTAINER_SIZE, 0), vmath.vector4(1,1,1,1), gui.PIVOT_CENTER)
    gui.set_parent(self.o_avatar_img, self.o_avatar_bg)
    pcall(function() gui.set_texture(self.o_avatar_img, "avatars"); gui.play_flipbook(self.o_avatar_img, hash("avatar_1")) end)

    self.o_avatar_name = label(vmath.vector3(0, 242, 0), "Opponent", 18, C_WHITE, gui.PIVOT_CENTER, "poppins_bold")
    gui.set_parent(self.o_avatar_name, self.hud_root)

    self.o_net = build_network_badge(self.hud_root, vmath.vector3(0, 345, 0))

    -- PLAYER 1 SECTION (Shifted slightly bottom)
    self.p_avatar_bg = box(vmath.vector3(0, -300, 0), vmath.vector3(AVATAR_CONTAINER_SIZE, AVATAR_CONTAINER_SIZE, 0), AVATAR_BG_COLOR, gui.PIVOT_CENTER)
    gui.set_parent(self.p_avatar_bg, self.hud_root)

    self.p_timer = gui.new_pie_node(vmath.vector3(0, 0, 0), vmath.vector3(TIMER_RADIUS*2, TIMER_RADIUS*2, 0))
    gui.set_rotation(self.p_timer, vmath.vector3(0, 0, 90))
    gui.set_parent(self.p_timer, self.p_avatar_bg)
    gui.set_enabled(self.p_timer, false)

    self.p_avatar_img = box(vmath.vector3(0, 0, 0), vmath.vector3(AVATAR_CONTAINER_SIZE, AVATAR_CONTAINER_SIZE, 0), vmath.vector4(1,1,1,1), gui.PIVOT_CENTER)
    gui.set_parent(self.p_avatar_img, self.p_avatar_bg)
    pcall(function() gui.set_texture(self.p_avatar_img, "avatars"); gui.play_flipbook(self.p_avatar_img, hash("avatar_1")) end)

    self.p_avatar_name = label(vmath.vector3(0, -242, 0), "You", 18, C_WHITE, gui.PIVOT_CENTER, "poppins_bold")
    gui.set_parent(self.p_avatar_name, self.hud_root)

    self.p_balance = label(vmath.vector3(0, -266, 0), "Bal: 0", 14, vmath.vector4(1, 0.85, 0.4, 1.0), gui.PIVOT_CENTER, "poppins")
    gui.set_parent(self.p_balance, self.hud_root)
    gui.set_enabled(self.p_balance, false)

    self.p_net = build_network_badge(self.hud_root, vmath.vector3(0, -345, 0))
end

-- Placing the Scoreboard flippers and game indicators...
local function build_scoreboard(self)
    -- Flip Clocks Stacked Vertically in Center (Opponent Top, Player Bottom)
    self.o_flipper = create_flipper(self.hud_root, vmath.vector3(0, 100, 0))
    self.p_flipper = create_flipper(self.hud_root, vmath.vector3(0, -100, 0))
    
    -- Opponent dots build UPWARD, Player dots build DOWNWARD to avoid middle overlap
    build_round_dots(self.o_flipper, true)
    build_round_dots(self.p_flipper, false)

    -- Central Divider & Text
    self.sb_div1 = box(vmath.vector3(0, 22, 0), vmath.vector3(120, 2, 0), vmath.vector4(0.2,0.2,0.2,1), gui.PIVOT_CENTER)
    self.sb_div2 = box(vmath.vector3(0, -22, 0), vmath.vector3(120, 2, 0), vmath.vector4(0.2,0.2,0.2,1), gui.PIVOT_CENTER)
    gui.set_parent(self.sb_div1, self.hud_root)
    gui.set_parent(self.sb_div2, self.hud_root)

    self.sb_title = label(vmath.vector3(0, 0, 0), "BEST OF 3", 15, C_WHITE, gui.PIVOT_CENTER, "poppins_bold")
    gui.set_parent(self.sb_title, self.hud_root)

    -- ── Head-to-head ALL TIME Column (Inner Left) ──────────────────────────────
    self.h2h_alltime_lbl = label(vmath.vector3(-110, 0, 0), "ALL TIME 0-0", 16, C_H2H_GOLD, gui.PIVOT_CENTER, "poppins_bold")
    gui.set_rotation(self.h2h_alltime_lbl, vmath.vector3(0, 0, -90))
    gui.set_parent(self.h2h_alltime_lbl, self.hud_root)
    gui.set_enabled(self.h2h_alltime_lbl, false)

    -- ── Head-to-head LAST 5 Container (Row Style, Dynamic Right, Below Deck) ────
    self.h2h_container = box(vmath.vector3(LOGICAL_W - 140, LOGICAL_H/2 - 180, 0), vmath.vector3(260, 80, 0), vmath.vector4(0.08, 0.08, 0.08, 0.85), gui.PIVOT_CENTER)
    gui.set_xanchor(self.h2h_container, gui.ANCHOR_RIGHT)
    gui.set_yanchor(self.h2h_container, gui.ANCHOR_NONE)
    gui.set_enabled(self.h2h_container, false)

    self.h2h_form_lbl = label(vmath.vector3(0, 22, 0), "YOUR LAST 5 GAMES WITH OPPONENT", 11, C_H2H_DIM, gui.PIVOT_CENTER, "poppins_bold")
    gui.set_parent(self.h2h_form_lbl, self.h2h_container)

    self.h2h_badges = {}
    for i = 1, 5 do
        local x_pos = (i - 3) * 42 -- -84, -42, 0, 42, 84
        local bg = box(vmath.vector3(x_pos, -10, 0), vmath.vector3(34, 34, 0), vmath.vector4(0.2, 0.2, 0.2, 0.5), gui.PIVOT_CENTER)
        gui.set_parent(bg, self.h2h_container)
        local lbl = label(vmath.vector3(0, 0, 0), "", 18, C_WHITE, gui.PIVOT_CENTER, "poppins_bold")
        gui.set_parent(lbl, bg)
        gui.set_enabled(bg, false)
        self.h2h_badges[i] = { bg = bg, lbl = lbl }
    end

    self.sb_root = self.hud_root
end

-- Show/hide the main scoreboard base (always visible if message.show ~= false)
local function set_scoreboard_active(self, active)
    if self.o_flipper then gui.set_enabled(self.o_flipper.root, active) end
    if self.p_flipper then gui.set_enabled(self.p_flipper.root, active) end
    if self.sb_div1 then gui.set_enabled(self.sb_div1, active) end
    if self.sb_div2 then gui.set_enabled(self.sb_div2, active) end
    if self.sb_title then gui.set_enabled(self.sb_title, active) end
end

-- Apply head-to-head data to the strip. h2h = { p, o, form = {"W","L",...} }
-- (viewer perspective, newest first) or nil to hide it.
local function set_h2h_strip(self, h2h, is_series)
    local has = type(h2h) == "table"
    local form = has and type(h2h.form) == "table" and h2h.form or {}
    local has_form = has and #form > 0
    
    -- If it is a series, we show the all time scores. If not, the main flippers show it!
    local show_alltime = has and is_series
    
    if self.h2h_container then 
        gui.set_enabled(self.h2h_container, has_form) 
        if has_form then
            local opp_name = self.opp_display_name or "OPPONENT"
            gui.set_text(self.h2h_form_lbl, "YOUR LAST 5 GAMES WITH " .. string.upper(opp_name))
        end
    end
    
    for i = 1, 5 do
        local badge = self.h2h_badges and self.h2h_badges[i]
        if badge then
            local r = form[i]
            if has and (r == "W" or r == "L") then
                gui.set_text(badge.lbl, r)
                gui.set_color(badge.bg, r == "W" and C_FORM_W or C_FORM_L)
                gui.set_enabled(badge.bg, true)
            else
                gui.set_enabled(badge.bg, false)
            end
        end
    end
    
    if self.h2h_alltime_lbl then
        if show_alltime then
            gui.set_text(self.h2h_alltime_lbl, "ALL TIME " .. tostring(h2h.p or 0) .. "-" .. tostring(h2h.o or 0))
            gui.set_enabled(self.h2h_alltime_lbl, true)
        else
            gui.set_enabled(self.h2h_alltime_lbl, false)
        end
    end
end

local function build_stake_chip(self)
    self.stake_chip = box(vmath.vector3(440, LOGICAL_H/2, 0), vmath.vector3(STAKE_CHIP_SIZE, STAKE_CHIP_SIZE, 0), vmath.vector4(1,1,1,1), gui.PIVOT_W)
    gui.set_xanchor(self.stake_chip, gui.ANCHOR_LEFT)
    gui.set_yanchor(self.stake_chip, gui.ANCHOR_NONE)
