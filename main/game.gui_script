-- AI takeover notices (flat design: Poppins, sharp corners, no shadows)

local AI_C_PANEL  = vmath.vector4(0.086, 0.098, 0.118, 1.0) -- #16191E
local AI_C_ACCENT = vmath.vector4(0.949, 0.702, 0.020, 1.0) -- #F2B305
local AI_C_BODY   = vmath.vector4(0.788, 0.812, 0.839, 1.0) -- #C9CFD6
local AI_C_DARK   = vmath.vector4(0.082, 0.094, 0.110, 1.0)

local function poppins(pos, text, px, color, bold, align)
    local n = gui.new_text_node(pos, text)
    gui.set_font(n, bold and "poppins_bold" or "poppins")
    local base = bold and 34 or 28
    gui.set_scale(n, vmath.vector3(px / base, px / base, 1.0))
    gui.set_color(n, color or C_WHITE)
    gui.set_pivot(n, align or gui.PIVOT_CENTER)
    return n
end

