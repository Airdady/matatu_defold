-- Timer Initialization and GUI Updating...
local function show_ai_notice(self, opts)
    opts = opts or {}
    if opts.mode == "TAKEOVER" then
        if self.ai_scrim then gui.set_enabled(self.ai_scrim, true) end
    else
        if not self.ai_banner then return end
        -- The assist allowance is capped: surface how much is left.
        local used = tonumber(opts.moves) or 0
        local max = tonumber(opts.max) or 3
        if self.ai_banner_lbl then
            if used > 0 then
                local txt = string.format("Time ran out — Akira played for you (%d of %d).", used, max)
                if used >= max then
                    txt = string.format("Akira played for you (%d of %d) — next timeout forfeits!", used, max)
                end
                gui.set_text(self.ai_banner_lbl, txt)
            else
                gui.set_text(self.ai_banner_lbl, "Time ran out — Akira played this move to protect your token.")
            end
        end
        gui.set_enabled(self.ai_banner, true)
        self._ai_banner_seq = (self._ai_banner_seq or 0) + 1
        local seq = self._ai_banner_seq
        timer.delay(4.0, false, function()
            if seq == self._ai_banner_seq and self.ai_banner then
                gui.set_enabled(self.ai_banner, false)
            end
        end)
    end
end

local function hide_ai_notices(self)
    if self.ai_scrim then gui.set_enabled(self.ai_scrim, false) end
    if self.ai_banner then gui.set_enabled(self.ai_banner, false) end
    self._ai_banner_seq = (self._ai_banner_seq or 0) + 1
end

local function set_conn_overlay(self, opts)
    if not self.conn_scrim then return end
    if opts and opts.show then
        gui.set_enabled(self.conn_scrim, true)
        gui.set_text(self.conn_title, opts.title or "RECONNECTING")
        gui.set_color(self.conn_title, opts.danger and C_T_RED or vmath.vector4(0.0, 0.722, 0.831, 1.0))
        gui.set_text(self.conn_sub, opts.subtitle or "")
        local grace = tonumber(opts.grace) or 0
        if grace > 0 then
            self.conn_deadline = socket.gettime() + grace
            self.conn_count_active = true
            gui.set_enabled(self.conn_count, true)
            gui.set_text(self.conn_count, string.format("%ds", math.ceil(grace)))
        else
            self.conn_count_active = false
            gui.set_enabled(self.conn_count, false)
            gui.set_text(self.conn_count, "")
        end
    else
        gui.set_enabled(self.conn_scrim, false)
        self.conn_count_active = false
    end
end

local function start_timer(self, is_player, duration, expires_at_ms)
    self.total_duration = duration or 30.0
    self.is_player_turn = is_player
    self.alert_played = false

    if expires_at_ms and expires_at_ms > 0 then
        local now_ms = socket.gettime() * 1000.0
        local remaining = (expires_at_ms - now_ms) / 1000.0
        self.timer_remaining = math.max(0, math.min(remaining, self.total_duration))
    else
        self.timer_remaining = self.total_duration
    end

    if is_player then
        if self.p_timer then
            gui.set_fill_angle(self.p_timer, (self.timer_remaining / self.total_duration) * 360)
            gui.set_color(self.p_timer, C_T_GREEN)
            gui.set_enabled(self.p_timer, true)
        end
        if self.o_timer then gui.set_enabled(self.o_timer, false) end
    else
        if self.o_timer then
            gui.set_fill_angle(self.o_timer, (self.timer_remaining / self.total_duration) * 360)
            gui.set_color(self.o_timer, C_T_GREEN)
            gui.set_enabled(self.o_timer, true)
        end
        if self.p_timer then gui.set_enabled(self.p_timer, false) end
    end
end

local function stop_timers(self)
    if self.p_timer then gui.set_enabled(self.p_timer, false) end
    if self.o_timer then gui.set_enabled(self.o_timer, false) end
    self.timer_remaining = 0
end

local function set_skip_visible(self, visible)
    if not self.skip_btn then return end

    if visible and not gui.is_enabled(self.skip_btn) then
        gui.set_enabled(self.skip_btn, true)
        gui.set_scale(self.skip_btn, vmath.vector3(0.9, 0.9, 1))
        local c = gui.get_color(self.skip_btn); c.w = 0; gui.set_color(self.skip_btn, c)

        gui.animate(self.skip_btn, "scale", vmath.vector3(1.0, 1.0, 1), gui.EASING_OUTBACK, 0.2)
        gui.animate(self.skip_btn, "color.w", 0.25, gui.EASING_OUTSINE, 0.2, 0, function()
            gui.animate(self.skip_btn, "scale", vmath.vector3(1.03, 1.03, 1), gui.EASING_INOUTSINE, 0.4, 0, nil, gui.PLAYBACK_LOOP_PINGPONG)
        end)
    elseif not visible and gui.is_enabled(self.skip_btn) then
        gui.cancel_animation(self.skip_btn, "scale")
        gui.cancel_animation(self.skip_btn, "color.w")
        gui.set_enabled(self.skip_btn, false)
    end
end

-- ── Round story overlay ─────────────────────────────────────────────────────
-- Full-screen interstitial between rounds of a series: "ROUND WON/LOST" →
-- dissolve → "ROUND 2" / "FINAL ROUND". While it plays, game.script holds the
-- incoming next-round state so the story finishes before the next deal.
local function build_round_story(self)
    self.story_scrim = box(vmath.vector3(LOGICAL_W/2, LOGICAL_H/2, 0), vmath.vector3(5000, 5000, 0), vmath.vector4(0, 0, 0, 0.88), gui.PIVOT_CENTER)
    gui.set_adjust_mode(self.story_scrim, gui.ADJUST_STRETCH)

    -- text scales via these wrappers so entrance/dissolve animations don't
    -- fight the font-size scale set by label()
    self.story_wrap = box(vmath.vector3(LOGICAL_W/2, LOGICAL_H/2 + 14, 0), vmath.vector3(1, 1, 0), vmath.vector4(0, 0, 0, 0), gui.PIVOT_CENTER)
    self.story_title = label(vmath.vector3(0, 24, 0), "", 54, C_WHITE, gui.PIVOT_CENTER, "title")
    pcall(function() gui.set_shadow(self.story_title, vmath.vector4(0, 0, 0, 0.7)) end)
    gui.set_parent(self.story_title, self.story_wrap)
    self.story_sub = label(vmath.vector3(0, -32, 0), "", 20, C_H2H_DIM, gui.PIVOT_CENTER, "body")
    gui.set_parent(self.story_sub, self.story_wrap)

    gui.set_enabled(self.story_scrim, false)
    gui.set_enabled(self.story_wrap, false)
    self.story_seq = 0
end

local function story_finish(self, seq)
    if seq ~= self.story_seq then return end
    gui.set_enabled(self.story_scrim, false)
    gui.set_enabled(self.story_wrap, false)
    self.story_active = false
    msg.post(GAME, "round_story_done")
end

-- One staged line: pop in (OUTBACK), hold, dissolve (fade + drift up).
local function story_phase(self, seq, title, sub, color, hold, next_fn)
    if seq ~= self.story_seq then return end
    gui.set_text(self.story_title, title)
    gui.set_color(self.story_title, color)
    gui.set_text(self.story_sub, sub or "")
    gui.set_enabled(self.story_wrap, true)

    gui.cancel_animation(self.story_wrap, "scale")
    gui.cancel_animation(self.story_wrap, "color.w")
    gui.set_scale(self.story_wrap, vmath.vector3(0.45, 0.45, 1))
    local c = gui.get_color(self.story_wrap); c.w = 0; gui.set_color(self.story_wrap, c)
    gui.animate(self.story_wrap, "color.w", 1.0, gui.EASING_OUTSINE, 0.22)
    gui.animate(self.story_wrap, "scale", vmath.vector3(1, 1, 1), gui.EASING_OUTBACK, 0.42, 0, function()
        if seq ~= self.story_seq then return end
        timer.delay(hold, false, function()
            if seq ~= self.story_seq then return end
            -- dissolve: fade out while gently scaling up
            gui.animate(self.story_wrap, "color.w", 0.0, gui.EASING_INSINE, 0.30)
            gui.animate(self.story_wrap, "scale", vmath.vector3(1.18, 1.18, 1), gui.EASING_INSINE, 0.30, 0, function()
                if seq ~= self.story_seq then return end
                next_fn()
            end)
        end)
    end)
end

local function show_round_story(self, m)
    self.story_seq = (self.story_seq or 0) + 1
    local seq = self.story_seq
    self.story_active = true

    gui.set_enabled(self.story_scrim, true)
    local sc = gui.get_color(self.story_scrim); sc.w = 0; gui.set_color(self.story_scrim, sc)
    gui.animate(self.story_scrim, "color.w", 0.88, gui.EASING_OUTSINE, 0.25)

    local p, o = tonumber(m.p_score) or 0, tonumber(m.o_score) or 0
    local won = m.won and true or false
    local opp = tostring(m.opp_name or "OPPONENT")

    local t1 = won and "ROUND WON!" or "ROUND LOST"
    local c1 = won and C_FORM_W or C_FORM_L
    local s1
    if p > o then s1 = string.format("You lead %d - %d", p, o)
    elseif o > p then s1 = string.format("%s leads %d - %d", opp, o, p)
    else s1 = string.format("All square at %d - %d", p, o) end

    local t2, c2, s2
    if m.last_round then
        t2, c2 = "FINAL ROUND", C_H2H_GOLD
        s2 = "Next win takes the match!"
    else
        t2, c2 = "ROUND " .. tostring(m.next_round or (p + o + 1)), C_STORY_CYAN
        s2 = won and "Keep the streak alive!" or "Time to bounce back!"
    end

    story_phase(self, seq, t1, s1, c1, 1.35, function()
        story_phase(self, seq, t2, s2, c2, 1.15, function()
            gui.animate(self.story_scrim, "color.w", 0.0, gui.EASING_INSINE, 0.28, 0, function()
                story_finish(self, seq)
            end)
        end)
    end)
end

local function hide_round_story(self)
    self.story_seq = (self.story_seq or 0) + 1
    self.story_active = false
    if self.story_scrim then gui.set_enabled(self.story_scrim, false) end
    if self.story_wrap then gui.set_enabled(self.story_wrap, false) end
end

-- Script Hooks: init, update, and input handling...
function init(self)
    msg.post(".", "acquire_input_focus")
    gui.set_render_order(13)

    self.timer_remaining = 0
    self.total_duration = 30.0
    self.is_player_turn = true
    self.my_id = ""

    build_avatars_and_sections(self)
    build_scoreboard(self)
    build_stake_chip(self)
    build_standings_ui(self)
    _create_skip_button(self)
    build_exit(self)
    build_conn_overlay(self)
    build_ai_takeover_modal(self)
    build_ai_assist_banner(self)
    build_round_story(self)

    -- HUD sets everything false on awake until specifically told to show via logic
    set_scoreboard_active(self, false)
    set_h2h_strip(self, nil, false)

    emoji_popover.init(self)
end

function update(self, dt)
    if self.conn_count_active then
        local left = (self.conn_deadline or 0) - socket.gettime()
        if left < 0 then left = 0 end
        gui.set_text(self.conn_count, string.format("%ds", math.ceil(left)))
        if left <= 0 then self.conn_count_active = false end
    end

    -- 4-player active-seat timer pie (depletes over the seat's turn; AI too).
    if self.t4_active_slot and self.t4_badges and self.t4_badges[self.t4_active_slot] then
        self.t4_timer_left = math.max(0, (self.t4_timer_left or 0) - dt)
        local frac = (self.t4_timer_total and self.t4_timer_total > 0) and (self.t4_timer_left / self.t4_timer_total) or 0
        local pie = self.t4_badges[self.t4_active_slot].pie
        if pie then
            gui.set_fill_angle(pie, frac * 360)
            local col = C_T_GREEN
            if frac < 0.33 then col = C_T_RED elseif frac < 0.66 then col = C_T_ORANGE end
            gui.set_color(pie, col)
        end
    end

    if self.timer_remaining and self.timer_remaining > 0 then
        self.timer_remaining = self.timer_remaining - dt
        if self.timer_remaining < 0 then self.timer_remaining = 0 end

        local progress = math.min(1.0, self.timer_remaining / self.total_duration)
        local active_pie = self.is_player_turn and self.p_timer or self.o_timer

        if active_pie then
            gui.set_fill_angle(active_pie, progress * 360)

            local c = C_T_RED
            if self.timer_remaining > self.total_duration / 2.0 then
                c = C_T_GREEN
            elseif self.timer_remaining > 5.0 then
                local t = 1.0 - ((self.timer_remaining - 5.0) / (self.total_duration / 2.0 - 5.0))
                c = vmath.lerp(t, C_T_GREEN, C_T_ORANGE)
            else
                local t = 1.0 - (self.timer_remaining / 5.0)
                c = vmath.lerp(t, C_T_ORANGE, C_T_RED)
            end
            gui.set_color(active_pie, c)

            if self.timer_remaining <= 10.0 and self.timer_remaining > 0 and self.is_player_turn and not self.alert_played then
                self.alert_played = true
                msg.post("/controller#snd_alert", "play_sound")
            end

            if self.timer_remaining <= 0 and self.is_player_turn then
                msg.post(GAME, "timer_expired")
            end
        end
    end
end

local function hit(node, action)
    if not node then return false end
    return gui.is_enabled(node) and gui.pick_node(node, action.x, action.y)
end

function on_input(self, action_id, action)
    if action_id ~= hash("touch") or not action.pressed then return false end

    -- Round story interstitial is modal: swallow taps while it plays.
    if self.story_active then return true end

    if emoji_popover.on_input(self, action_id, action) then
        return true
    end

    if self.ai_scrim and gui.is_enabled(self.ai_scrim) then
        if hit(self.ai_ok_btn, action) then
            gui.set_enabled(self.ai_scrim, false)
            msg.post(GAME, "ai_notice_ack")
        end
        return true
    end

    if self.exit_popover and gui.is_enabled(self.exit_popover) then
        if hit(self.btn_yes, action) then
            gui.set_enabled(self.exit_popover, false)
            msg.post(GAME, "exit_to_lobby")
            return true
        elseif hit(self.btn_no, action) then
            gui.set_enabled(self.exit_popover, false)
            return true
        end
        return true
    end

    if self.exit_btn and hit(self.exit_btn, action) then
        if self.exit_popover then gui.set_enabled(self.exit_popover, true) end
        return true
    end

    if self.skip_btn and gui.is_enabled(self.skip_btn) and hit(self.skip_btn, action) then
        msg.post(GAME, "skip_pressed")
        return true
    end

    return false
end

-- Message passing router to process external Game State data...
function on_message(self, message_id, message)
    if message_id == hash("setup_avatars") then
        local o_name = (message.op_info and message.op_info.username) or (message.op_info and message.op_info.name) or "Opponent"

        if string.len(o_name) > 10 then
            o_name = string.sub(o_name, 1, 10) .. "..."
        end
        o_name = string.upper(o_name)
        self.opp_display_name = o_name

        -- The bottom seat is always the current user: label it YOU; the
        -- opponent seat carries their name in bold.
        if self.p_avatar_name then gui.set_text(self.p_avatar_name, "YOU") end
        if self.o_avatar_name then gui.set_text(self.o_avatar_name, o_name) end

        gui.set_enabled(self.p_balance, true)
        local bal = (message.my_info and message.my_info.balance) or 0
        if self.p_balance then gui.set_text(self.p_balance, "Bal: " .. tostring(bal)) end
        self.my_id = (message.my_info and message.my_info.id) or ""

        local p_av = (message.my_info and message.my_info.avatar) or 1
        local o_av = (message.op_info and message.op_info.avatar) or 1
        pcall(function() gui.play_flipbook(self.p_avatar_img, hash("avatar_" .. tostring(p_av))) end)
        pcall(function() gui.play_flipbook(self.o_avatar_img, hash("avatar_" .. tostring(o_av))) end)

    -- ── 4-player tournament: opponent seat badge (name + live count + avatar)
    -- ── 4-player tournament HUD ──────────────────────────────────────────
    elseif message_id == hash("t4_mode") then
        -- Hide the 2-player avatar HUD; the per-seat widgets take over.
        if message.on then
            if self.p_avatar_bg then gui.set_enabled(self.p_avatar_bg, false) end
            if self.o_avatar_bg then gui.set_enabled(self.o_avatar_bg, false) end
        end

    elseif message_id == hash("t4_clear") then
        if self.t4_badges then
            for _, b in pairs(self.t4_badges) do
                pcall(gui.delete_node, b.pie); pcall(gui.delete_node, b.disc)
                pcall(gui.delete_node, b.av);  pcall(gui.delete_node, b.nm); pcall(gui.delete_node, b.ct)
            end
        end
        self.t4_badges = {}
        self.t4_active_slot = nil

    elseif message_id == hash("t4_seat") then
        self.t4_badges = self.t4_badges or {}
        local slot = message.slot or "top"
        local x, y = message.x or 0, message.y or 0
        local b = self.t4_badges[slot]
        if not b then
            -- timer pie ring BEHIND the avatar (depletes on the active turn)
            local pie = gui.new_pie_node(vmath.vector3(x, y + 10, 0), vmath.vector3(76, 76, 0))
            gui.set_rotation(pie, vmath.vector3(0, 0, 90))
            gui.set_parent(pie, self.hud_root)
            gui.set_enabled(pie, false)
            local disc = box(vmath.vector3(x, y + 10, 0), vmath.vector3(64, 64, 0), vmath.vector4(0.06, 0.07, 0.10, 1), gui.PIVOT_CENTER)
            local av = box(vmath.vector3(x, y + 10, 0), vmath.vector3(58, 58, 0), vmath.vector4(1,1,1,1), gui.PIVOT_CENTER)
            pcall(function() gui.set_texture(av, "avatars"); gui.play_flipbook(av, hash("avatar_" .. tostring(message.avatar or 1))) end)
            local nm = label(vmath.vector3(x, y - 30, 0), "", 13, C_WHITE, gui.PIVOT_CENTER)
            local ct = label(vmath.vector3(x, y - 48, 0), "", 13, vmath.vector4(1,0.84,0.2,1), gui.PIVOT_CENTER)
            b = { pie = pie, disc = disc, av = av, nm = nm, ct = ct }
            self.t4_badges[slot] = b
        end
        gui.set_text(b.nm, string.upper(tostring(message.name or "AI")))
        gui.set_text(b.ct, (message.eliminated and "OUT") or (tostring(message.count or 0) .. (message.count == 1 and " card" or " cards")))
        local frame_col = message.eliminated and vmath.vector4(0.22,0.05,0.05,1)
            or (message.active and vmath.vector4(0.10,0.12,0.05,1) or vmath.vector4(0.06,0.07,0.10,1))
        gui.set_color(b.disc, frame_col)
        if not message.active then gui.set_enabled(b.pie, false) end

    elseif message_id == hash("t4_active") then
        -- Start (or clear) the active seat's depleting timer pie.
        self.t4_active_slot = message.slot
        self.t4_timer_total = message.duration or 3
        self.t4_timer_left  = self.t4_timer_total
        for s, b in pairs(self.t4_badges or {}) do
            if s == message.slot then
                gui.set_enabled(b.pie, true)
                gui.set_fill_angle(b.pie, 360)
                gui.set_color(b.pie, C_T_GREEN)
            else
                gui.set_enabled(b.pie, false)
            end
        end

    elseif message_id == hash("t4_count") then
        -- Counting pass: pulse the seat being tallied and flash its number.
        local b = (self.t4_badges or {})[message.slot]
        if b then
            gui.set_color(b.disc, vmath.vector4(0.16, 0.18, 0.06, 1))
            gui.set_scale(b.av, vmath.vector3(1.18, 1.18, 1))
            gui.animate(b.av, "scale", vmath.vector3(1, 1, 1), gui.EASING_OUTSINE, 0.5)
            gui.set_text(b.ct, "= " .. tostring(message.count or 0))
        end

    elseif message_id == hash("t4_flash") then
        local fl = label(vmath.vector3(LOGICAL_W/2, LOGICAL_H/2 + 80, 0), tostring(message.text or ""), 40, vmath.vector4(1, 0.84, 0.2, 1), gui.PIVOT_CENTER, "title")
        gui.set_scale(fl, vmath.vector3(0.5, 0.5, 1))
        gui.animate(fl, "scale", vmath.vector3(1.1, 1.1, 1), gui.EASING_OUTBACK, 0.3)
        gui.animate(fl, "color.w", 0, gui.EASING_INSINE, 0.5, 0.7, function() pcall(gui.delete_node, fl) end)

    elseif message_id == hash("t4_eliminated") then
        local txt = string.upper(tostring(message.name or "A player")) .. " LEAVES THE TABLE  -  " .. tostring(message.remaining or 0) .. " LEFT"
        local toast = box(vmath.vector3(LOGICAL_W/2, LOGICAL_H/2, 0), vmath.vector3(620, 70, 0), vmath.vector4(0.06, 0.07, 0.10, 0.97), gui.PIVOT_CENTER)
        gui.set_xanchor(toast, gui.ANCHOR_NONE); gui.set_yanchor(toast, gui.ANCHOR_NONE)
        local strip = box(vmath.vector3(0, 32, 0), vmath.vector3(620, 5, 0), vmath.vector4(0.95, 0.27, 0.2, 1), gui.PIVOT_CENTER)
        gui.set_parent(strip, toast)
        local lbl = label(vmath.vector3(0, 0, 0), txt, 20, C_WHITE, gui.PIVOT_CENTER)
        gui.set_parent(lbl, toast)
        gui.set_scale(toast, vmath.vector3(0.85, 0.85, 1))
        gui.animate(toast, "scale", vmath.vector3(1, 1, 1), gui.EASING_OUTBACK, 0.3)
        timer.delay(2.0, false, function() pcall(gui.delete_node, toast) end)

    elseif message_id == hash("turn") then
        local is_p = (message.who == "player")
        start_timer(self, is_p, message.duration or 30.0, message.expires_at)

    elseif message_id == hash("skip") then
        set_skip_visible(self, message.show)

    elseif message_id == hash("update_balance") then
        -- Settled balance pushed the moment a game ends.
        local bal = tonumber(message.balance)
        if bal and self.p_balance then
            gui.set_text(self.p_balance, "Bal: " .. tostring(bal))
            gui.set_enabled(self.p_balance, true)
        end

    elseif message_id == hash("update_scoreboard") then
        if message.show == false then
            set_scoreboard_active(self, false)
            set_h2h_strip(self, nil, false)
            hide_round_dots(self.o_flipper)
            hide_round_dots(self.p_flipper)
            return
        end

        local state = message.state or message.game_state or message
        local is_tournament = false

        if state and type(state) == "table" then
            if state.tournamentId or state.tournament or state.tournamentScore then
                is_tournament = true
            end
            if state.gameOverState and type(state.gameOverState) == "table" then
                if state.gameOverState.tournamentId or state.gameOverState.tournamentData then
                    is_tournament = true
                end
            end
        end

        local series = message.series
        if series == nil then series = true end

        -- Override if it's a tournament: it behaves like a 'series' because we show progress on the flippers
        if is_tournament then
            series = true
        end

        -- Default Score Variables
        local best_of = 3
        local p_score = 0
        local o_score = 0
        local stage = "Match"

        -- Extract Match Format dynamically
        if state and type(state) == "table" then
            if state.matchFormat then best_of = state.matchFormat end

            if state.tournamentScore and type(state.tournamentScore) == "table" then
                best_of = state.tournamentScore.matchFormat or best_of
                stage = "Level " .. tostring(state.tournamentScore.currentLevel or 1)
                local scores = state.tournamentScore.scores
                if scores and type(scores) == "table" then
                    p_score = scores[self.my_id] or p_score
                    for k, v in pairs(scores) do
                        if k ~= self.my_id then o_score = v; break end
                    end
                end
            end

            if state.tournament and type(state.tournament) == "table" then
                best_of = state.tournament.matchFormat or best_of
                local stg = state.tournament.stageName
                if stg and stg ~= "" then stage = stg
                elseif state.tournament.level then stage = "Level " .. tostring(state.tournament.level) end
            end

            if state.gameOverState and type(state.gameOverState) == "table" then
                local scores = state.gameOverState.currentScores
                if scores and type(scores) == "table" then
                    p_score = scores[self.my_id] or p_score
                    for k, v in pairs(scores) do
                        if k ~= self.my_id then o_score = v; break end
                    end
                end
            end
        end

        -- Safe Overrides
        if message.p_score then p_score = message.p_score end
        if message.o_score then o_score = message.o_score end
        if message.best_of then best_of = message.best_of end
        if message.stage then stage = message.stage end

        local h2h = (type(message.h2h) == "table") and message.h2h or nil

        -- ALWAYS make the core scoreboard active if we reach this point
        set_scoreboard_active(self, true)
        
        -- Show H2H side-strip, pass 'series' to appropriately hide/show the all time text score
        set_h2h_strip(self, h2h, series)

        if series then
            -- Calculate Required Wins
            local target = math.floor(best_of / 2) + 1

            -- Run the 3D Flip Anim logic for tournament/series progress
            animate_flipper(self.o_flipper, string.format("%02d", o_score))
            animate_flipper(self.p_flipper, string.format("%02d", p_score))

            -- Round dots attached seamlessly inside the scoreboards
            set_round_dots(self.o_flipper, target, o_score, true)
            set_round_dots(self.p_flipper, target, p_score, true)

            -- Format Title Details
            local title = "BEST OF " .. tostring(best_of)
            if is_tournament then
                if stage and stage ~= "" then title = title .. "  •  " .. string.upper(stage) end
            else
                if stage and stage ~= "Match" then title = title .. "  •  " .. string.upper(stage) end
            end
            if self.sb_title then gui.set_text(self.sb_title, title) end
        else
            -- Normal game (not series/tournament): flip clocks display all-time head-to-head score
            animate_flipper(self.o_flipper, string.format("%02d", (h2h and h2h.o) or 0))
            animate_flipper(self.p_flipper, string.format("%02d", (h2h and h2h.p) or 0))
            hide_round_dots(self.o_flipper)
            hide_round_dots(self.p_flipper)
            if self.sb_title then gui.set_text(self.sb_title, "ALL TIME") end
        end

    elseif message_id == hash("round_story") then
        local m = message or {}
        m.opp_name = m.opp_name or self.opp_display_name
        show_round_story(self, m)

    -- Routing matching the Godot implementation: parses active state and visually highlights
    elseif message_id == hash("update_standings") then
        -- FIXED: Do not sort the raw reference, duplicate it first
        local raw_ranks = message.ranks or {}
        local ranks = {}
        for _, r in ipairs(raw_ranks) do table.insert(ranks, r) end
        
        table.sort(ranks, function(a, b) return (tonumber(a.position) or 9999) < (tonumber(b.position) or 9999) end)
        
        if self.standings_title then gui.set_enabled(self.standings_title, #ranks > 0) end
        
        for i=1, 3 do
            local row = self.standings_rows[i]
            if not row then break end
            
            if ranks[i] then
                gui.set_enabled(row.bg, true)
                gui.set_text(row.pos, "#" .. tostring(ranks[i].position or 0))
                
                local raw_active = ranks[i].active
                local is_active = false
                if type(raw_active) == "boolean" then is_active = raw_active
                elseif type(raw_active) == "string" then is_active = (string.lower(raw_active) == "true") end
                
                local nm = tostring(ranks[i].username or "Player")
                if is_active then
                    nm = "YOU"
                elseif #nm > 7 then
                    nm = string.sub(nm, 1, 7) .. "…"
                end
                
                gui.set_text(row.name, string.upper(nm))
                gui.set_text(row.pts, tostring(ranks[i].points or 0))

                local pos_c = is_active and vmath.vector4(1, 0.84, 0, 1) or vmath.vector4(0.6, 0.6, 0.6, 1)
                local nm_c  = is_active and vmath.vector4(1, 1, 1, 1) or vmath.vector4(0.8, 0.8, 0.8, 0.8)
                local pts_c = is_active and vmath.vector4(1, 1, 1, 1) or vmath.vector4(0.7, 0.7, 0.7, 0.8)
                local s_size = is_active and 20 or 16
                
                gui.set_color(row.pos, pos_c)
                gui.set_color(row.name, nm_c)
                gui.set_color(row.pts, pts_c)
                
                gui.set_scale(row.pos, vmath.vector3(s_size/24, s_size/24, 1))
                gui.set_scale(row.name, vmath.vector3(s_size/24, s_size/24, 1))
                gui.set_scale(row.pts, vmath.vector3(s_size/24, s_size/24, 1))
            else
                gui.set_enabled(row.bg, false)
            end
        end

    elseif message_id == hash("update_stake") then
        local s = message.amount
        local amount = (type(s) == "table") and (tonumber(s.amount) or 0) or (tonumber(s) or 0)
        if not self.stake_chip then
        elseif amount < 200 then
            gui.set_enabled(self.stake_chip, false)
        else
            local img = "stake_200"
            if      amount >= 10000 then img = "stake_10000"
            elseif amount >= 5000  then img = "stake_5000"
            elseif amount >= 2000  then img = "stake_2000"
            elseif amount >= 1000  then img = "stake_1000"
            elseif amount >= 500   then img = "stake_500" end
            local ok = pcall(function()
                gui.set_texture(self.stake_chip, "ui")
                gui.play_flipbook(self.stake_chip, hash(img))
            end)
            gui.set_enabled(self.stake_chip, ok)
        end

    elseif message_id == hash("network_quality") then
        local badge = (message.user_id == self.my_id) and self.p_net or self.o_net
        if not badge then return end
        local ms = message.latency_ms or 0
        -- Godot thresholds: <200 good, <500 fair, beyond that poor.
        local txt, col = "Good", C_T_GREEN
        if ms >= 500 then txt, col = "Poor", C_T_RED
        elseif ms >= 200 then txt, col = "Fair", vmath.vector4(0.98, 0.75, 0.14, 1.0) end

        gui.set_text(badge.lbl, txt)
        gui.set_color(badge.lbl, col)
        gui.set_color(badge.dot, col)

    elseif message_id == hash("stop_timers") then
        stop_timers(self)

    elseif message_id == hash("conn_overlay") then
        set_conn_overlay(self, message)

    elseif message_id == hash("ai_takeover_notice") then
        show_ai_notice(self, message)

    elseif message_id == hash("emoji_received") then
        emoji_popover.on_message(self, message_id, message)

    elseif message_id == hash("reset_hud") then
        stop_timers(self)
        set_skip_visible(self, false)
        set_conn_overlay(self, { show = false })
        hide_ai_notices(self)
        if self.exit_popover then gui.set_enabled(self.exit_popover, false) end

        -- Drop any 4-player tournament seat widgets + restore the 2-player HUD.
        if self.t4_badges then
            for _, b in pairs(self.t4_badges) do
                pcall(gui.delete_node, b.pie); pcall(gui.delete_node, b.disc)
                pcall(gui.delete_node, b.av);  pcall(gui.delete_node, b.nm); pcall(gui.delete_node, b.ct)
            end
            self.t4_badges = nil
        end
        self.t4_active_slot = nil
        if self.p_avatar_bg then gui.set_enabled(self.p_avatar_bg, true) end
        if self.o_avatar_bg then gui.set_enabled(self.o_avatar_bg, true) end

        -- A round transition inside the same series keeps the live scoreboard
        -- and head-to-head strip on screen (values are updated in place);
        -- only a full reset — leaving the board — clears them.
        -- The round-story interstitial survives a keep_scoreboard reset (a
        -- round transition re-init happens UNDER it); a full reset kills it.
        if not (message and message.keep_scoreboard) then
            hide_round_story(self)
            set_scoreboard_active(self, false)
            set_h2h_strip(self, nil, false)
            snap_flipper(self.o_flipper, "00")
            snap_flipper(self.p_flipper, "00")
            hide_round_dots(self.o_flipper)
            hide_round_dots(self.p_flipper)
            
            -- Wiping the stake chip and standings should ONLY happen if we are 
            -- completely resetting the HUD, not keeping the scoreboard.
            if self.stake_chip then gui.set_enabled(self.stake_chip, false) end
            if self.standings_title then gui.set_enabled(self.standings_title, false) end
            for _, row in ipairs(self.standings_rows or {}) do gui.set_enabled(row.bg, false) end
        end

        emoji_popover.reset(self)
    end
end