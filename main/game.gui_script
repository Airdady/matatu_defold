-- Building Standings UI aligned right below the exit button
local function build_standings_ui(self)
    -- Rankings live on the RIGHT, below the exit button, above the deck.
    local st_y = LOGICAL_H - EXIT_BTN_MARGIN_TOP - EXIT_BTN_SIZE - 20
    local st_x = LOGICAL_W - EXIT_BTN_MARGIN_RIGHT

    self.standings_root = box(vmath.vector3(st_x, st_y, 0), vmath.vector3(220, 180, 0), vmath.vector4(0,0,0,0), gui.PIVOT_NE)
    gui.set_xanchor(self.standings_root, gui.ANCHOR_RIGHT)
    gui.set_yanchor(self.standings_root, gui.ANCHOR_TOP)

    self.standings_title = label(vmath.vector3(-220, 0, 0), "STANDINGS", 13, vmath.vector4(0.65, 0.68, 0.72, 1.0), gui.PIVOT_NW, "poppins_bold")
    gui.set_parent(self.standings_title, self.standings_root)
    gui.set_enabled(self.standings_title, false)

    self.standings_rows = {}
    -- Only showing 3 top players as per prompt
    for i=1, 3 do
        local row_y = -24 - (i-1)*28
        local row = box(vmath.vector3(-220, row_y, 0), vmath.vector3(220, 24, 0), vmath.vector4(0,0,0,0), gui.PIVOT_NW)
        gui.set_parent(row, self.standings_root)
        
        local pos_lbl = label(vmath.vector3(0, -12, 0), "", 16, C_WHITE, gui.PIVOT_W, "poppins_bold")
        local name_lbl = label(vmath.vector3(35, -12, 0), "", 16, C_WHITE, gui.PIVOT_W, "poppins_bold")
        local pts_lbl = label(vmath.vector3(220, -12, 0), "", 16, C_WHITE, gui.PIVOT_E, "poppins_bold")
        
        gui.set_parent(pos_lbl, row)
        gui.set_parent(name_lbl, row)
        gui.set_parent(pts_lbl, row)
        
        table.insert(self.standings_rows, { bg=row, pos=pos_lbl, name=name_lbl, pts=pts_lbl })
    end
end

